              <Properties>
                <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;b&gt;Platzhalter f&#xfc;r Dateinamen und F&#xe4;lligkeitstexte:&lt;/b&gt; {DATUM.heute_iso}=yyyy-MM-dd, {DATUM.heute}=dd.MM.yyyy, {DATUM.jahr}, {DATUM.monat}, {DATUM.tag}&lt;br&gt;{AKTE.fileNumber}=Aktenzeichen, {AKTE.name}=Aktenname, {AKTE.reason}=Wegen, {AKTE.subjectField}=Sachgebiet, {AKTE.id}=ID, {AKTE.lawyer}=Anwalt, {AKTE.assistant}=Sachbearbeiter, {USER.current}=angemeldeter Benutzer&lt;br&gt;{BETEILIGTER.name}, {BETEILIGTER.typ}, {BETEILIGTER.aktenzeichen}, {BETEILIGTER.id}=aktueller Beteiligter bei Erstellung je Beteiligtem&lt;/html&gt;"/>
                <Property name="toolTipText" type="java.lang.String" value="&lt;html&gt;Diese Platzhalter k&#xf6;nnen in Dokument-Dateinamen sowie in Titel und Beschreibung von F&#xe4;lligkeiten verwendet werden.&lt;br&gt;Beispiel Dateiname: {DATUM.heute_iso}_{AKTE.fileNumber}_{AKTE.name}&lt;/html&gt;"/>
              </Properties>
