<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <!--
        Public browser-login endpoints (OpenSpec add-web-client, Decision 5): the SPA is not
        yet authenticated when it calls /rest/v8/auth/login|refresh|logout, so this more
        specific pattern (no auth-constraint) makes those paths public. The container's Basic
        challenge therefore never fires for the login, and the endpoint returns a plain 401
        without WWW-Authenticate. All other paths remain behind the loginRole constraint below.
    -->
    <security-constraint>
        <display-name>PublicAuthEndpoints</display-name>
        <web-resource-collection>
            <web-resource-name>auth</web-resource-name>
            <url-pattern>/rest/v8/auth/*</url-pattern>
        </web-resource-collection>
    </security-constraint>
    <security-constraint>
        <display-name>Constraint1</display-name>
        <web-resource-collection>
            <web-resource-name>default</web-resource-name>
            <description/>
            <url-pattern>/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <description>need at least login role</description>
            <role-name>loginRole</role-name>
        </auth-constraint>
    </security-constraint>
    <login-config>
        <auth-method>BASIC</auth-method>
        <realm-name>jlawyerRealm</realm-name>
    </login-config>
    <context-param>
        <param-name>resteasy.role.based.security</param-name>
        <param-value>true</param-value>
    </context-param>
    <security-role>
        <description/>
        <role-name>loginRole</role-name>
    </security-role>
    <ejb-local-ref>
        <ejb-ref-name>ServerSettingsBeanFacade</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.persistence.ServerSettingsBeanFacadeLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#ServerSettingsBeanFacade</ejb-link>
    </ejb-local-ref>
    <ejb-local-ref>
        <ejb-ref-name>FaxQueueBeanFacade</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.persistence.FaxQueueBeanFacadeLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#FaxQueueBeanFacade</ejb-link>
    </ejb-local-ref>
    <ejb-local-ref>
        <ejb-ref-name>VoipService</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.services.VoipServiceLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#VoipService</ejb-link>
    </ejb-local-ref>
    <ejb-local-ref>
        <ejb-ref-name>SystemManagement</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.services.SystemManagementLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#SystemManagement</ejb-link>
    </ejb-local-ref>
    <ejb-local-ref>
        <ejb-ref-name>ArchiveFileService</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.services.ArchiveFileServiceLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#ArchiveFileService</ejb-link>
    </ejb-local-ref>
    <ejb-local-ref>
        <ejb-ref-name>FormsService</ejb-ref-name>
        <ejb-ref-type>Session</ejb-ref-type>
        <local>com.jdimension.jlawyer.services.FormsServiceLocal</local>
        <ejb-link>j-lawyer-server-ejb.jar#FormsService</ejb-link>
    </ejb-local-ref>
</web-app>
