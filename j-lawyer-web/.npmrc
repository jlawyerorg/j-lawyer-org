# Supply-chain hardening for j-lawyer-web — see SUPPLY-CHAIN.md
# (Change add-web-client, design.md Decision 2c)

# Neutralise malicious pre/postinstall scripts of dependencies.
# NOTE: legitimate toolchain packages needing install scripts must be vetted-allowlisted
# (e.g. @lavamoat/allow-scripts), NOT globally re-enabled. Verify esbuild in the spike.
ignore-scripts=true

# Pin exact versions — no ^/~ ranges — so the lockfile is the single source of truth.
save-exact=true

# Always keep a lockfile; installs go through `npm ci` (fails on lockfile drift).
package-lock=true

# Fail if the local Node/npm does not satisfy package.json "engines".
engine-strict=true

# No funding/telemetry noise.
fund=false

# Audit is a dedicated CI gate (`npm audit --audit-level=high`), not run on every install.
audit=false

# --- Controlled registry (enable ONE once seeded; see SUPPLY-CHAIN.md) -----------------
# Option A (vendored offline cache, faithful to maven-repo/): resolve from seeded cache
#   prefer-offline=true
# Option B (internal proxy registry, e.g. Verdaccio/Nexus):
#   registry=http://<internal-registry>/
